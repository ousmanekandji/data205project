library(tidyverse)
library(lubridate)

food <- read_csv("FoodInspectionData_cleaned.csv")
closed <- read_csv("Closed_Food_Establishments_cleaned.csv")

# Closure rate
closure_rate <- nrow(closed) / nrow(food)
closure_rate

# City risk
total <- food %>% count(City)
closed_counts <- closed %>% count(City)

left_join(total, closed_counts, by = "City") %>%
  mutate(rate = n.y / n.x)

# Trend correlation
trend_df <- closed %>%
  mutate(month = floor_date(Inspection.Date, "month")) %>%
  count(month) %>%
  mutate(time = row_number())

cor.test(trend_df$time, trend_df$n)
